# Backend environment variables
# Copy to ".env" and fill values.

PORT=5000
NODE_ENV=development

# CORS
# Single origin:
# FRONTEND_URL=https://your-frontend.vercel.app
#
# Or multiple origins (comma-separated):
FRONTEND_URLS=http://localhost:3000,https://erp-frontend-pied-chi.vercel.app

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# Postgres (use either DATABASE_URL OR the DB_* vars below)
# DATABASE_URL=postgres://ahmed:erp2463@196.221.144.213:5432/erpdb

# Optional: set to "true" if your Postgres requires SSL in non-production
# DB_SSL=true
# Optional: set to "false" to accept self-signed certs
# DB_SSL_REJECT_UNAUTHORIZED=false

DB_HOST=196.221.144.213
DB_PORT=5432
DB_NAME=erpdb
DB_USER=ahmed
DB_PASSWORD=erp2463

